{
    "dashboard": {
        "id": null,
        "uid": null,
        "title": "WhatsApp Assistant Monitoring",
        "timezone": "browser",
        "panels": [
            {
                "title": "Request Latency",
                "type": "graph",
                "datasource": "YourDatasource",
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[5m])) by (le))",
                        "format": "time_series",
                        "interval": "",
                        "intervalFactor": 2,
                        "legendFormat": "P95"
                    }
                ]
            },
            {
                "title": "Error Rate",
                "type": "singlestat",
                "datasource": "YourDatasource",
                "targets": [
                    {
                        "expr": "sum(rate(request_errors_total[5m])) / sum(rate(requests_total[5m]))",
                        "format": "time_series",
                        "interval": "",
                        "instant": true
                    }
                ]
            }
        ],
        "refresh": "5s"
    }
}